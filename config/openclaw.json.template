{
  "_comment": "web3-mkt-agents config template. Replace ALL {{PLACEHOLDER}} values before use.",
  "_version": "1.0.0",
  "_docs": "https://github.com/YOUR_USERNAME/web3-mkt-agents",

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_AUTH_TOKEN}}"
    }
  },

  "agents": {
    "defaults": {
      "heartbeat": {
        "model": "google/gemini-2.5-flash-lite"
      }
    },
    "list": [
      {
        "id": "pm",
        "default": true,
        "name": "PM Agent",
        "workspace": "~/.openclaw/workspace-pm",
        "model": "anthropic/claude-sonnet-4-6",
        "description": "Central orchestrator. Routes all tasks, monitors agents, weekly reports."
      },
      {
        "id": "social",
        "name": "Social Agent",
        "workspace": "~/.openclaw/workspace-social",
        "model": "minimax/minimax-m2.5",
        "description": "Twitter/X, LinkedIn, meme generation, trend monitoring."
      },
      {
        "id": "content",
        "name": "Content Agent",
        "workspace": "~/.openclaw/workspace-content",
        "model": "anthropic/claude-sonnet-4-6",
        "description": "Blog, video scripts, design briefs, SEO optimization."
      },
      {
        "id": "data",
        "name": "Data Agent",
        "workspace": "~/.openclaw/workspace-data",
        "model": "openai/gpt-4.1-nano",
        "description": "Token monitoring, competitor scan, social/SEO analytics, KPI reports."
      },
      {
        "id": "bd",
        "name": "BD Agent",
        "workspace": "~/.openclaw/workspace-bd",
        "model": "openai/gpt-4.1",
        "description": "Prospect research, cold email drafting, proposals, follow-ups, event scouting."
      },
      {
        "id": "finance",
        "name": "Finance Agent",
        "workspace": "~/.openclaw/workspace-finance",
        "model": "anthropic/claude-sonnet-4-6",
        "description": "Invoice processing, budget tracking, contract monitoring, CPM reporting."
      },
      {
        "id": "eco",
        "name": "Ecosystem Agent",
        "workspace": "~/.openclaw/workspace-eco",
        "model": "minimax/minimax-m2.5",
        "description": "Event announcements, brand analysis, ecosystem partner prospecting."
      },
      {
        "id": "community",
        "name": "Community Agent",
        "workspace": "~/.openclaw/workspace-community",
        "model": "openai/gpt-4o-mini",
        "description": "Discord/TG sentiment monitoring, FAQ auto-reply, crisis drafting, announcements."
      },
      {
        "id": "security",
        "name": "Security Agent",
        "workspace": "~/.openclaw/workspace-security",
        "model": "google/gemini-2.5-flash-lite",
        "description": "Impersonation scan, phishing detection, API audit, account anomaly monitoring."
      }
    ]
  },

  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "apiKey": "{{ANTHROPIC_API_KEY}}"
      },
      "openai": {
        "apiKey": "{{OPENAI_API_KEY}}"
      },
      "minimax": {
        "apiKey": "{{MINIMAX_API_KEY}}"
      },
      "google": {
        "apiKey": "{{GEMINI_API_KEY}}"
      }
    }
  },

  "channels": {
    "telegram": {
      "accounts": {
        "pm":        { "botToken": "{{TG_TOKEN_PM}}" },
        "social":    { "botToken": "{{TG_TOKEN_SOCIAL}}" },
        "content":   { "botToken": "{{TG_TOKEN_CONTENT}}" },
        "data":      { "botToken": "{{TG_TOKEN_DATA}}" },
        "bd":        { "botToken": "{{TG_TOKEN_BD}}" },
        "finance":   { "botToken": "{{TG_TOKEN_FINANCE}}" },
        "eco":       { "botToken": "{{TG_TOKEN_ECO}}" },
        "community": { "botToken": "{{TG_TOKEN_COMMUNITY}}" },
        "security":  { "botToken": "{{TG_TOKEN_SECURITY}}" }
      }
    },
    "slack": {
      "botToken": "{{SLACK_BOT_TOKEN}}",
      "channels": {
        "approvals":      "{{SLACK_APPROVALS_CHANNEL_ID}}",
        "weeklyReport":   "{{SLACK_WEEKLY_REPORT_CHANNEL_ID}}",
        "alerts":         "{{SLACK_ALERTS_CHANNEL_ID}}",
        "securityAlerts": "{{SLACK_SECURITY_CHANNEL_ID}}",
        "bdPipeline":     "{{SLACK_BD_CHANNEL_ID}}",
        "finance":        "{{SLACK_FINANCE_CHANNEL_ID}}"
      }
    }
  },

  "env": {
    "NOTION_TOKEN":                "{{NOTION_TOKEN}}",
    "NOTION_TASK_DB_ID":           "{{NOTION_TASK_DB_ID}}",
    "NOTION_CONTENT_DB_ID":        "{{NOTION_CONTENT_DB_ID}}",
    "NOTION_MEMORY_DB_ID":         "{{NOTION_MEMORY_DB_ID}}",
    "NOTION_BD_DB_ID":             "{{NOTION_BD_DB_ID}}",
    "NOTION_FINANCE_DB_ID":        "{{NOTION_FINANCE_DB_ID}}",
    "NOTION_CRM_DB_ID":            "{{NOTION_CRM_DB_ID}}",
    "TWITTER_BEARER_TOKEN":        "{{TWITTER_BEARER_TOKEN}}",
    "TWITTER_API_KEY":             "{{TWITTER_API_KEY}}",
    "TWITTER_API_SECRET":          "{{TWITTER_API_SECRET}}",
    "TWITTER_ACCESS_TOKEN":        "{{TWITTER_ACCESS_TOKEN}}",
    "TWITTER_ACCESS_SECRET":       "{{TWITTER_ACCESS_SECRET}}",
    "TWITTER_OWN_USER_ID":         "{{TWITTER_OWN_USER_ID}}",
    "LINKEDIN_ACCESS_TOKEN":       "{{LINKEDIN_ACCESS_TOKEN}}",
    "LINKEDIN_COMPANY_ID":         "{{LINKEDIN_COMPANY_ID}}",
    "DISCORD_BOT_TOKEN":           "{{DISCORD_BOT_TOKEN}}",
    "DISCORD_GUILD_ID":            "{{DISCORD_GUILD_ID}}",
    "DISCORD_MONITOR_CHANNEL_IDS": "{{DISCORD_MONITOR_CHANNEL_IDS}}",
    "DISCORD_ANNOUNCE_CHANNEL_ID": "{{DISCORD_ANNOUNCE_CHANNEL_ID}}",
    "TG_COMMUNITY_CHAT_ID":        "{{TG_COMMUNITY_CHAT_ID}}",
    "TG_CHANNEL_ID":               "{{TG_CHANNEL_ID}}",
    "COINGECKO_API_KEY":           "{{COINGECKO_API_KEY}}",
    "SERPAPI_KEY":                 "{{SERPAPI_KEY}}",
    "APOLLO_API_KEY":              "{{APOLLO_API_KEY}}",
    "HUNTER_API_KEY":              "{{HUNTER_API_KEY}}",
    "SENDGRID_API_KEY":            "{{SENDGRID_API_KEY}}",
    "SENDGRID_FROM_EMAIL":         "{{SENDGRID_FROM_EMAIL}}",
    "GOOGLE_SAFE_BROWSING_KEY":    "{{GOOGLE_SAFE_BROWSING_KEY}}",
    "WHOISXML_API_KEY":            "{{WHOISXML_API_KEY}}",
    "GCAL_CREDENTIALS":            "{{GCAL_CREDENTIALS_PATH}}",
    "GCAL_CALENDAR_ID":            "{{GCAL_CALENDAR_ID}}",
    "GSHEETS_CREDENTIALS":         "{{GSHEETS_CREDENTIALS_PATH}}",
    "GSHEETS_DATA_SHEET_ID":       "{{GSHEETS_DATA_SHEET_ID}}",
    "GSHEETS_FINANCE_SHEET_ID":    "{{GSHEETS_FINANCE_SHEET_ID}}",
    "GDRIVE_CREDENTIALS":          "{{GDRIVE_CREDENTIALS_PATH}}",
    "GDRIVE_INVOICE_FOLDER_ID":    "{{GDRIVE_INVOICE_FOLDER_ID}}",
    "GDRIVE_CONTENT_FOLDER_ID":    "{{GDRIVE_CONTENT_FOLDER_ID}}"
  },

  "memory": {
    "contextWindow": {
      "softThresholdTokens": 40000,
      "compactionModel": "minimax/minimax-m2.5"
    }
  }
}
